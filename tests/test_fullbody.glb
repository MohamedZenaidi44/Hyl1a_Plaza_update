<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Login</title>
    <!-- <link rel="stylesheet" href="/main.css" /> -->
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta property="og:title" content="Mii Creator - Web-based Mii editor" />
    <meta property="og:description" content="Create and share Mii characters online with just a few clicks!" />
    <meta name="description" content="Create and share Mii characters online with just a few clicks!" />
    <meta name="keywords" content="Mii, Mii Creator, Nintendo, Pretendo, FFL, Wii U, 3DS, Mii Maker, Web Mii Maker" />
    <meta property="theme-color" content="#484848" />
    <meta property="og:site_name" content="mii.nxw.pw" />
    <meta property="og:image" content="https://mii.nxw.pw/assets/images/preview2025.png" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content="https://mii.nxw.pw/assets/images/preview2025.png" />
    <link rel="shortcut icon" href="/assets/images/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/assets/images/favicon.ico" type="image/x-icon" />
    <style>
      html,
      body {
        height: 100%;
        margin: 0;
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Oxygen,
          Ubuntu,
          Cantarell,
          "Open Sans",
          "Helvetica Neue",
          sans-serif;
      }
      body {
        background-color: black;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
        gap: 0.8vmax;
      }
      button {
        appearance: none;
        border: 0;
        border-radius: 8px;
        cursor: pointer;
        font: inherit;
        color: #fff;
        transition:
          background-color 0.1s ease-out,
          box-shadow 0.1s ease-out,
          transform 0.4s cubic-bezier(0.47, 1.64, 0.41, 0.8);
      }
      button.discord {
        background-color: #5865f2;
        box-shadow: 0 6px 0 0 #434ec8;
        padding: 20px 26px;
      }
      button.discord:hover {
        background-color: #505bd9;
        box-shadow: 0 6px 0 0 #3640b1;
      }
      button.discord:active {
        transform: translateY(10px);
        background-color: #424cb5;
        box-shadow: 0 0px 0 0 #232a79;
      }
      button.guest {
        background-color: hsl(0, 1%, 49%);
        box-shadow: 0 6px 0 0 hsl(235, 0%, 45%);
        padding: 4px 26px;
      }
      button.guest:hover {
        background-color: hsl(0, 1%, 49%);
        box-shadow: 0 6px 0 0 hsl(235, 0%, 45%);
      }
      button.guest:active {
        transform: translateY(10px);
        background-color: hsl(235, 0%, 48%);
        box-shadow: 0 0px 0 0 hsl(235, 0%, 31%);
      }
      button.local {
        background-color: #5865f2;
        box-shadow: 0 6px 0 0 #434ec8;
      }
      button.local:hover {
        background-color: #505bd9;
        box-shadow: 0 6px 0 0 #3640b1;
      }
      button.local:active {
        transform: translateY(10px);
        background-color: #424cb5;
        box-shadow: 0 0px 0 0 #232a79;
      }
      #bg {
        background-image: url("data:image/svg+xml,%3Csvg width='2033' height='1533' viewBox='0 0 2033 1533' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Cg opacity='0.28'%3E%3Cpath d='M863.159 536.482C601.151 587.736 430.301 841.686 481.556 1103.69C532.81 1365.7 786.76 1536.55 1048.77 1485.3C1310.78 1434.04 1481.63 1180.09 1430.37 918.085C1379.12 656.077 1125.17 485.227 863.159 536.482Z' stroke='%2327B7FF' stroke-opacity='0.28' stroke-width='75.3351'/%3E%3Cpath d='M1204.65 320.143C1082.11 344.114 1002.21 462.883 1026.18 585.421C1050.15 707.959 1168.92 787.864 1291.46 763.893C1414 739.922 1493.9 621.152 1469.93 498.614C1445.96 376.076 1327.19 296.171 1204.65 320.143Z' stroke='%2327B7FF' stroke-opacity='0.28' stroke-width='35.2334'/%3E%3Cpath d='M389.759 42.8529C151.857 89.3917 -3.27386 319.977 43.265 557.879C89.8038 795.781 320.389 950.912 558.291 904.373C796.193 857.834 951.324 627.249 904.785 389.347C858.246 151.445 627.661 -3.68596 389.759 42.8529Z' stroke='%2327B7FF' stroke-opacity='0.28' stroke-width='68.4039'/%3E%3Cpath d='M734.58 684.821C647.913 701.775 591.4 785.775 608.354 872.442C625.308 959.108 709.309 1015.62 795.975 998.667C882.641 981.713 939.154 897.713 922.2 811.046C905.247 724.38 821.246 667.867 734.58 684.821Z' stroke='%2327B7FF' stroke-opacity='0.28' stroke-width='24.9191'/%3E%3Cpath d='M1582.36 717.007C1390.38 754.564 1265.19 940.645 1302.74 1132.63C1340.3 1324.62 1526.38 1449.81 1718.37 1412.25C1910.35 1374.69 2035.54 1188.61 1997.99 996.627C1960.43 804.64 1774.35 679.451 1582.36 717.007Z' stroke='%2327B7FF' stroke-opacity='0.28' stroke-width='55.2017'/%3E%3C/g%3E%3C/svg%3E");
        background-size: cover;
        background-position: center;
        background-attachment: fixed;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: -1;
        pointer-events: none;
      }
      header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 12px;
        margin-bottom: 2vmax;
      }
      #image-1 {
        position: fixed;
        bottom: -3vmax;
        right: 2.5vmax;
        pointer-events: none;
      }
      #image-2 {
        position: fixed;
        bottom: -3vmax;
        left: 2.5vmax;
        pointer-events: none;
      }
      @media screen and (max-width: 1280px) {
        #image-1 {
          position: fixed;
          bottom: -12vh;
          height: 50%;
        }
        #image-2 {
          position: fixed;
          bottom: -12vh;
          height: 50%;
        }
      }
      @media screen and (max-width: 640px) {
        #image-1 {
          display: none;
        }
        #image-2 {
          bottom: -16vh;
          left: 50%;
          transform: translateX(-50%);
          z-index: -1;
        }
      }
      @keyframes appear {
        from {
          opacity: 0;
        }
        to {
          opacity: 1;
        }
      }
      @keyframes loader {
        from {
          transform: rotate(0deg);
        }
        to {
          transform: rotate(360deg);
        }
      }
      .loader-window {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        right: 0;
        z-index: 10;
        background: #000a;
        backdrop-filter: blur(6px) brightness(0.9);
        justify-content: center;
        align-items: center;
        opacity: 0;
        display: none;
        transition: opacity 0.4s ease-out;
      }
      .loader-window.active {
        display: flex;
        opacity: 1;
        animation: appear 0.4s ease-out forwards;
      }
      .loader {
        animation: loader 0.5s linear infinite;
      }
      .list {
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      #error {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        padding: 16px 24px;
        background: #851a1aaa;
        color: #ffffff;
        font-weight: bold;
        display: flex;
        justify-content: center;
        pointer-events: none;
        opacity: 0;
      }
      #error.active {
        opacity: 1;
        animation: appear 0.4s ease-out forwards;
      }

      details {
        position: fixed;
        bottom: 0;
        right: 0;
        z-index: 10;
      }
      summary {
        cursor: pointer;
      }
    </style>
  </head>

  <body>
