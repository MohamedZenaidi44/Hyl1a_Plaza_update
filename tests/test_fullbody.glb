    <script>
      function loader() {
        document.querySelector(".loader-window").classList.add("active");
        setTimeout(() => {
          document.querySelector(".loader-window").classList.remove("active");
        }, 3000);
      }
      window.onload = () => {
        document.querySelector("form").addEventListener("submit", (a) => {
          loader();
        });
      };
      if (location.href.includes("?to")) {
        document.getElementById("error").classList.add("active");
        document.getElementById("error").textContent = "This action requires you to be logged in.";
        sessionStorage.setItem("loc", location.search);
      }
    </script>

    <div class="list">
      <form action="/auth/discord" id="discord">
        <button type="submit" class="discord" aria-label="Discord login button">
